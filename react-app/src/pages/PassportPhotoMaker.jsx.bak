import { useEffect, useRef } from 'react'
import Navbar from '../components/Navbar'
import '../styles/passport-photo.css'

export default function PassportPhotoMaker() {
  const initialized = useRef(false)

  useEffect(() => {
    if (initialized.current) return
    initialized.current = true

    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    //  BGrade Passport Photo Maker â€” Full Application Logic
    // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    const $ = id => document.getElementById(id)
    const state = {
      originalImageUrl: null,
      processedImageUrl: null,
      cropper: null,
      croppedCanvas: null,
      bgColor: '#ffffff',
      borderColor: '#cccccc',
      borderWidth: 1,
      photoW: 3, photoH: 4,
      paperW: 21, paperH: 29.7,
      copies: 4,
      brightness: 100,
      contrast: 100,
      saturation: 100,
      sharpness: 20,
      step: 1,
    }

    // â”€â”€ Toast â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    function showToast(msg, type = 'info') {
      const icons = { success: 'ph-check-circle', error: 'ph-x-circle', info: 'ph-info' }
      const t = document.createElement('div')
      t.className = `toast ${type}`
      t.innerHTML = `<i class="ph ${icons[type]}"></i><span>${msg}</span>`
      const container = $('toast-container')
      if (container) container.appendChild(t)
      setTimeout(() => t.remove(), 4000)
    }

    // â”€â”€ Step Navigation â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    function goToStep(n) {
      state.step = n
      ;['step-1-btn', 'step-2-btn', 'step-3-btn'].forEach((id, i) => {
        const el = $(id); if (!el) return
        el.classList.remove('active', 'done')
        if (i + 1 < n) el.classList.add('done')
        else if (i + 1 === n) el.classList.add('active')
      })
      $('view-upload').style.display = n === 1 ? '' : 'none'
      $('view-editor').style.display = n === 2 ? '' : 'none'
      $('view-output').style.display = n === 3 ? '' : 'none'
    }

    // â”€â”€ File Upload â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    const fileInput = $('file-input')
    const uploadZone = $('upload-zone')
    if (!fileInput || !uploadZone) return

    $('upload-btn').onclick = () => fileInput.click()
    uploadZone.onclick = (e) => { if (e.target !== $('upload-btn')) fileInput.click() }
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over') })
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'))
    uploadZone.addEventListener('drop', e => {
      e.preventDefault(); uploadZone.classList.remove('drag-over')
      const file = e.dataTransfer.files[0]; if (file) handleFile(file)
    })
    fileInput.onchange = () => { if (fileInput.files[0]) handleFile(fileInput.files[0]) }

    function handleFile(file) {
      if (!file.type.startsWith('image/')) { showToast('Please upload an image file.', 'error'); return }
      if (file.size > 15 * 1024 * 1024) { showToast('File too large. Max 15MB.', 'error'); return }
      const url = URL.createObjectURL(file)
      state.originalImageUrl = url; state.processedImageUrl = null
      loadImageIntoEditor(url)
    }

    function loadImageIntoEditor(url) {
      const img = $('cropper-img')
      if (state.cropper) { state.cropper.destroy(); state.cropper = null }
      img.style.display = 'block'
      $('canvas-placeholder').style.display = 'none'
      $('preview-canvas').style.display = 'none'
      img.src = url
      img.onload = () => {
        const ratio = state.photoW / state.photoH
        state.cropper = new window.Cropper(img, {
          aspectRatio: ratio, viewMode: 1, autoCropArea: 0.85,
          movable: true, rotatable: true, scalable: true, zoomable: true,
          background: false, guides: true, highlight: true, cropBoxResizable: true,
        })
      }
      goToStep(2)
      showToast('Photo loaded. Crop and adjust, then click Generate.', 'info')
    }

    $('btn-change-photo').onclick = () => {
      if (state.cropper) { state.cropper.destroy(); state.cropper = null }
      $('cropper-img').style.display = 'none'
      $('preview-canvas').style.display = 'none'
      $('canvas-placeholder').style.display = ''
      goToStep(1)
    }
    $('btn-back-edit').onclick = () => goToStep(2)

    // â”€â”€ Crop Apply â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    $('btn-crop-apply').onclick = () => {
      if (!state.cropper) { showToast('Please upload a photo first.', 'error'); return }
      const canvas = state.cropper.getCroppedCanvas({ width: 600, height: Math.round(600 * state.photoH / state.photoW) })
      state.croppedCanvas = canvas
      const img = $('cropper-img')
      state.cropper.destroy(); state.cropper = null
      img.style.display = 'none'
      renderPreviewCanvas()
      showToast('Crop applied!', 'success')
    }

    function renderPreviewCanvas() {
      if (!state.croppedCanvas) return
      const pc = $('preview-canvas'); if (!pc) return
      pc.style.display = 'block'
      const ctx = pc.getContext('2d')
      const w = state.croppedCanvas.width; const h = state.croppedCanvas.height
      pc.width = w; pc.height = h
      ctx.fillStyle = state.bgColor; ctx.fillRect(0, 0, w, h)
      ctx.filter = `brightness(${state.brightness}%) contrast(${state.contrast}%) saturate(${state.saturation}%)`
      ctx.drawImage(state.croppedCanvas, 0, 0, w, h)
      ctx.filter = 'none'
      if (state.borderWidth > 0) {
        const bw = state.borderWidth * 2
        ctx.strokeStyle = state.borderColor; ctx.lineWidth = bw
        ctx.strokeRect(bw / 2, bw / 2, w - bw, h - bw)
      }
    }

    // â”€â”€ AI Background Removal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    $('btn-remove-bg').onclick = async () => {
      const srcUrl = state.processedImageUrl || state.originalImageUrl
      if (!srcUrl) { showToast('Please upload a photo first.', 'error'); return }
      const processing = $('ai-processing')
      processing.classList.add('visible')
      try {
        if (window.BackgroundRemoval) {
          const blob = await fetch(srcUrl).then(r => r.blob())
          const resultBlob = await window.BackgroundRemoval.removeBackground(blob, { model: 'small', output: { format: 'image/png', quality: 0.9 } })
          const url = URL.createObjectURL(resultBlob)
          state.processedImageUrl = url
          loadImageIntoEditor(url)
          showToast('Background removed successfully!', 'success')
        } else {
          await simulateBgRemoval(srcUrl)
          showToast('Background removed (basic mode).', 'info')
        }
      } catch (err) {
        await simulateBgRemoval(srcUrl)
        showToast('AI BG removal done (fallback mode).', 'info')
      } finally {
        processing.classList.remove('visible')
      }
    }

    async function simulateBgRemoval(srcUrl) {
      return new Promise(resolve => {
        const img = new Image(); img.crossOrigin = 'anonymous'
        img.onload = () => {
          const canvas = document.createElement('canvas')
          canvas.width = img.width; canvas.height = img.height
          const ctx = canvas.getContext('2d'); ctx.drawImage(img, 0, 0)
          const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height)
          const data = imageData.data
          const samples = [[0,0],[img.width-1,0],[0,img.height-1],[img.width-1,img.height-1],[Math.floor(img.width/2),0],[0,Math.floor(img.height/2)]]
          let rAvg=0,gAvg=0,bAvg=0
          samples.forEach(([x,y])=>{ const i=(y*img.width+x)*4; rAvg+=data[i]; gAvg+=data[i+1]; bAvg+=data[i+2] })
          rAvg/=samples.length; gAvg/=samples.length; bAvg/=samples.length
          for (let i=0;i<data.length;i+=4) {
            if (Math.abs(data[i]-rAvg)+Math.abs(data[i+1]-gAvg)+Math.abs(data[i+2]-bAvg)<180) data[i+3]=0
          }
          ctx.putImageData(imageData, 0, 0)
          const finalCanvas=document.createElement('canvas'); finalCanvas.width=img.width; finalCanvas.height=img.height
          const fCtx=finalCanvas.getContext('2d'); fCtx.fillStyle=state.bgColor; fCtx.fillRect(0,0,finalCanvas.width,finalCanvas.height); fCtx.drawImage(canvas,0,0)
          finalCanvas.toBlob(blob=>{ const url=URL.createObjectURL(blob); state.processedImageUrl=url; loadImageIntoEditor(url); resolve() },'image/png')
        }
        img.src = srcUrl
      })
    }

    $('btn-reset').onclick = () => {
      if (state.originalImageUrl) { state.processedImageUrl=null; loadImageIntoEditor(state.originalImageUrl); showToast('Reset to original photo.','info') }
    }

    // â”€â”€ Generate Photo Sheet â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    $('btn-generate').onclick = () => {
      if (!state.croppedCanvas && state.cropper) state.croppedCanvas=state.cropper.getCroppedCanvas({width:600})
      if (!state.croppedCanvas) { showToast('Please apply crop first.','error'); return }
      generatePhotoSheet()
    }

    function generatePhotoSheet() {
      if (!state.croppedCanvas) { showToast('Please apply crop first.','error'); return }
      const DPI=96; const CM_TO_PX=DPI/2.54
      const pW=Math.round(state.paperW*CM_TO_PX); const pH=Math.round(state.paperH*CM_TO_PX)
      const photoW=Math.round(state.photoW*CM_TO_PX); const photoH=Math.round(state.photoH*CM_TO_PX)
      const margin=Math.round(0.5*CM_TO_PX); const gap=Math.round(0.3*CM_TO_PX)
      const cols=Math.floor((pW-2*margin+gap)/(photoW+gap)); const rows=Math.floor((pH-2*margin+gap)/(photoH+gap))
      const totalSlots=Math.min(cols*rows,state.copies)
      const canvas=$('output-canvas'); canvas.width=pW; canvas.height=pH
      const ctx=canvas.getContext('2d')
      ctx.fillStyle='#ffffff'; ctx.fillRect(0,0,pW,pH)
      let count=0
      outer: for (let r=0;r<rows;r++) {
        for (let c=0;c<cols;c++) {
          if (count>=state.copies) break outer
          const x=margin+c*(photoW+gap); const y=margin+r*(photoH+gap)
          ctx.fillStyle=state.bgColor; ctx.fillRect(x,y,photoW,photoH)
          ctx.filter=`brightness(${state.brightness}%) contrast(${state.contrast}%) saturate(${state.saturation}%)`
          ctx.drawImage(state.croppedCanvas,x,y,photoW,photoH)
          ctx.filter='none'
          if (state.borderWidth>0) { ctx.strokeStyle=state.borderColor; ctx.lineWidth=state.borderWidth; ctx.strokeRect(x,y,photoW,photoH) }
          const nameVal=$('stamp-name').value.trim()
          if (nameVal) {
            ctx.fillStyle='rgba(0,0,0,0.75)'; ctx.fillRect(x,y+photoH-20,photoW,20)
            ctx.fillStyle='#fff'; ctx.font=`bold ${Math.round(photoW*0.065)}px Inter,sans-serif`; ctx.textAlign='center'
            ctx.fillText(nameVal,x+photoW/2,y+photoH-6); ctx.textAlign='left'
          }
          if ($('stamp-date').checked) {
            const dateStr=new Date().toLocaleDateString('en-IN')
            ctx.fillStyle='rgba(0,0,0,0.55)'; ctx.font=`${Math.round(photoW*0.055)}px Inter,sans-serif`
            ctx.textAlign='right'; ctx.fillText(dateStr,x+photoW-5,y+photoH-5); ctx.textAlign='left'
          }
          count++
        }
      }
      ctx.fillStyle='#94a3b8'; ctx.font='10px Inter,sans-serif'
      ctx.fillText(`Amrit Enterprises â€¢ ${state.photoW}Ã—${state.photoH}cm â€¢ ${state.copies} copies`,margin,pH-margin+14)
      goToStep(3)
      showToast(`Generated ${count} photos on ${state.paperW}Ã—${state.paperH}cm sheet.`,'success')
    }

    // â”€â”€ Download â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    $('btn-download-pdf').onclick = () => {
      const canvas=$('output-canvas'); if (!canvas.width) { showToast('Generate photos first.','error'); return }
      const {jsPDF}=window.jspdf
      const pdf=new jsPDF({orientation:state.paperH>state.paperW?'portrait':'landscape',unit:'cm',format:[state.paperW,state.paperH]})
      pdf.addImage(canvas.toDataURL('image/jpeg',0.95),'JPEG',0,0,state.paperW,state.paperH)
      pdf.save('AmritEnterprises-passport-photos.pdf')
      showToast('PDF downloaded!','success')
    }
    $('btn-download-png').onclick = () => {
      const canvas=$('output-canvas'); if (!canvas.width) { showToast('Generate photos first.','error'); return }
      const link=document.createElement('a'); link.download='AmritEnterprises-passport-photos.png'; link.href=canvas.toDataURL('image/png'); link.click()
      showToast('PNG downloaded!','success')
    }

    // â”€â”€ Size Presets â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.onclick = () => {
        document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'))
        btn.classList.add('active')
        const w=parseFloat(btn.dataset.w); const h=parseFloat(btn.dataset.h)
        if (w===0) {
          const row=$('custom-size-row')
          row.style.display=row.style.display==='flex'?'none':'flex'
        } else {
          state.photoW=w; state.photoH=h
          if (state.cropper) state.cropper.setAspectRatio(w/h)
          $('custom-size-row').style.display='none'
        }
      }
    })
    ;[$('custom-w'),$('custom-h')].forEach(inp => {
      if (inp) inp.oninput = () => {
        const w=parseFloat($('custom-w').value); const h=parseFloat($('custom-h').value)
        if (w>0&&h>0) { state.photoW=w; state.photoH=h; if (state.cropper) state.cropper.setAspectRatio(w/h) }
      }
    })

    // â”€â”€ Background Colors â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    document.querySelectorAll('#bg-colors .color-swatch').forEach(sw => {
      if (sw.classList.contains('custom')) return
      sw.onclick = () => {
        document.querySelectorAll('#bg-colors .color-swatch').forEach(s=>s.classList.remove('active'))
        sw.classList.add('active'); state.bgColor=sw.dataset.color
        if (state.croppedCanvas) renderPreviewCanvas()
      }
    })
    const customColorPicker=$('custom-color-picker')
    document.querySelector('.color-swatch.custom')?.addEventListener('click',()=>customColorPicker.click())
    customColorPicker?.addEventListener('input',()=>{
      state.bgColor=customColorPicker.value
      document.querySelectorAll('#bg-colors .color-swatch').forEach(s=>s.classList.remove('active'))
      if (state.croppedCanvas) renderPreviewCanvas()
    })

    // â”€â”€ Border Colors â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    document.querySelectorAll('#border-colors .color-swatch').forEach(sw => {
      sw.onclick = () => {
        document.querySelectorAll('#border-colors .color-swatch').forEach(s=>s.classList.remove('active'))
        sw.classList.add('active'); state.borderColor=sw.dataset.color
        if (state.croppedCanvas) renderPreviewCanvas()
      }
    })

    // â”€â”€ Adjustments â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    const sliderMap = [
      ['sl-brightness','val-brightness','brightness'],['sl-contrast','val-contrast','contrast'],
      ['sl-saturation','val-saturation','saturation'],['sl-sharpness','val-sharpness','sharpness']
    ]
    sliderMap.forEach(([slId,valId,key]) => {
      const sl=$(slId); if (!sl) return
      sl.oninput=()=>{ state[key]=parseInt(sl.value); $(valId).textContent=sl.value; if(state.croppedCanvas) renderPreviewCanvas() }
    })

    // â”€â”€ Border Width â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    const slBorder=$('sl-border')
    if (slBorder) slBorder.oninput=()=>{ state.borderWidth=parseInt(slBorder.value); $('val-border').textContent=slBorder.value; if(state.croppedCanvas) renderPreviewCanvas() }

    // â”€â”€ Print options â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    document.querySelectorAll('.print-opt').forEach(btn => {
      btn.onclick = () => {
        document.querySelectorAll('.print-opt').forEach(b=>b.classList.remove('active'))
        btn.classList.add('active')
        state.paperW=parseFloat(btn.dataset.pw); state.paperH=parseFloat(btn.dataset.ph)
      }
    })
    $('copies-minus').onclick=()=>{ if(state.copies>1){state.copies--; $('copies-val').textContent=state.copies} }
    $('copies-plus').onclick=()=>{ if(state.copies<20){state.copies++; $('copies-val').textContent=state.copies} }

    // FAQ toggle
    window.toggleFaq = function(el) {
      const answer=el.nextElementSibling
      const icon=el.querySelector('.faq-icon')
      const isOpen=answer.style.display==='block'
      answer.style.display=isOpen?'none':'block'
      if(icon) icon.style.transform=isOpen?'':'rotate(180deg)'
    }

    return () => {
      if (state.cropper) { try { state.cropper.destroy() } catch(e){} }
      if (state.originalImageUrl) URL.revokeObjectURL(state.originalImageUrl)
      if (state.processedImageUrl) URL.revokeObjectURL(state.processedImageUrl)
    }
  }, [])

  return (
    <>
      <Navbar />
      <div className="toast-container" id="toast-container"></div>

      {/* â”€â”€â”€ Full-width dark studio header â”€â”€â”€ */}
      <div className="studio-header">
        <div className="studio-glare"></div>
        <div className="studio-header-inner">
          <div className="studio-title-block">
            <span className="studio-badge">
              <i className="ph ph-shield-check"></i> On-Device AI Â· Zero Uploads
            </span>
            <h1>Passport &amp; Visa<br /><em>Photo Studio</em></h1>
            <p>Instant, government-compliant photos from your browser. AI lifts backgrounds on-device â€” your images never touch a server.</p>
          </div>
          <div className="studio-steps">
            <div className="studio-step active" id="step-1-btn">
              <span className="sstep-num">01</span>
              <span className="sstep-label">Upload</span>
            </div>
            <div className="sstep-line"></div>
            <div className="studio-step" id="step-2-btn">
              <span className="sstep-num">02</span>
              <span className="sstep-label">Edit</span>
            </div>
            <div className="sstep-line"></div>
            <div className="studio-step" id="step-3-btn">
              <span className="sstep-num">03</span>
              <span className="sstep-label">Export</span>
            </div>
          </div>
        </div>
      </div>

      {/* â”€â”€â”€ Studio workspace: dark sidebar + light main â”€â”€â”€ */}
      <div className="studio-workspace">

        {/* LEFT: Dark Controls Sidebar */}
        <aside className="studio-sidebar">

          <div className="sb-section">
            <h3 className="sb-title"><i className="ph ph-ruler"></i> Photo Size</h3>
            <div className="sb-presets" id="size-presets">
              {[
                {n:'Standard',s:'3Ã—4 cm',w:3,h:4},{n:'Indian Passport',s:'3.5Ã—4.5 cm',w:3.5,h:4.5},
                {n:'US Passport',s:'2Ã—2 inch',w:5.08,h:5.08},{n:'Aadhaar Card',s:'2.5Ã—3 cm',w:2.5,h:3},
                {n:'PAN Card',s:'2.5Ã—3.5 cm',w:2.5,h:3.5},{n:'Visa Photo',s:'3.5Ã—4.5 cm',w:3.5,h:4.5},
                {n:'Stamp Size',s:'2Ã—2.5 cm',w:2,h:2.5},
              ].map(({n,s,w,h},i) => (
                <button key={n} className={`preset-btn${i===0?' active':''}`} data-w={w} data-h={h} data-unit="cm">
                  <span className="preset-name">{n}</span><span className="preset-size">{s}</span>
                </button>
              ))}
              <button className="preset-btn" data-w="0" data-h="0">
                <span className="preset-name">Custom</span><span className="preset-size">Set dimensions</span>
              </button>
            </div>
            <div id="custom-size-row" style={{display:'none',gap:'0.5rem',marginTop:'0.5rem',alignItems:'center'}}>
              <input type="number" id="custom-w" placeholder="W (cm)" min="1" max="20" step="0.1" className="sb-input" />
              <span className="sb-sep">Ã—</span>
              <input type="number" id="custom-h" placeholder="H (cm)" min="1" max="20" step="0.1" className="sb-input" />
            </div>
          </div>

          <div className="sb-divider"></div>

          <div className="sb-section">
            <h3 className="sb-title"><i className="ph ph-paint-bucket"></i> Background</h3>
            <div className="sb-swatches" id="bg-colors">
              {[
                {c:'#ffffff',t:'White'},{c:'#4a90d9',t:'Blue'},{c:'#e8f0fe',t:'Light Blue'},
                {c:'#dc2626',t:'Red'},{c:'#f0fdf4',t:'Soft Green'},{c:'#fafafa',t:'Off-White'},{c:'#1e293b',t:'Dark'},
              ].map(({c,t},i) => (
                <div key={c} className={`color-swatch${i===0?' active':''}`} data-color={c} style={{background:c}} title={t}></div>
              ))}
              <div className="color-swatch custom" title="Pick color">
                <i className="ph ph-eyedropper"></i>
                <input type="color" id="custom-color-picker" defaultValue="#6366f1" />
              </div>
            </div>
          </div>

          <div className="sb-divider"></div>

          <div className="sb-section">
            <h3 className="sb-title"><i className="ph ph-sliders-horizontal"></i> Adjustments</h3>
            {[
              {id:'sl-brightness',vid:'val-brightness',label:'Brightness',min:50,max:150,def:100},
              {id:'sl-contrast',vid:'val-contrast',label:'Contrast',min:50,max:150,def:100},
              {id:'sl-saturation',vid:'val-saturation',label:'Saturation',min:0,max:200,def:100},
              {id:'sl-sharpness',vid:'val-sharpness',label:'Sharpness',min:0,max:100,def:20},
            ].map(({id,vid,label,min,max,def}) => (
              <div className="slider-row" key={id}>
                <label>{label}</label>
                <input type="range" id={id} min={min} max={max} defaultValue={def} />
                <span className="slider-val" id={vid}>{def}</span>
              </div>
            ))}
          </div>

          <div className="sb-divider"></div>

          <div className="sb-section">
            <h3 className="sb-title"><i className="ph ph-printer"></i> Paper &amp; Copies</h3>
            <div className="sb-print-grid" id="print-options">
              {[
                {p:'A4',pw:21,ph:29.7,s:'210Ã—297mm'},{p:'A5',pw:14.8,ph:21,s:'148Ã—210mm'},
                {p:'4Ã—6',pw:10.16,ph:15.24,s:'102Ã—152mm'},{p:'Letter',pw:21.59,ph:27.94,s:'215Ã—279mm'},
              ].map(({p,pw,ph,s},i) => (
                <button key={p} className={`print-opt${i===0?' active':''}`} data-paper={p} data-pw={pw} data-ph={ph}>
                  <span className="popt-label">{p}</span><span className="popt-size">{s}</span>
                </button>
              ))}
            </div>
            <div className="copies-row">
              <span className="copies-label">Copies per sheet</span>
              <div className="copies-ctrl">
                <button className="copies-btn" id="copies-minus">âˆ’</button>
                <span id="copies-val">4</span>
                <button className="copies-btn" id="copies-plus">+</button>
              </div>
            </div>
          </div>

          <div className="sb-divider"></div>

          <div className="sb-section">
            <h3 className="sb-title"><i className="ph ph-frame-corners"></i> Border</h3>
            <div className="slider-row">
              <label>Width</label>
              <input type="range" id="sl-border" min="0" max="10" defaultValue="1" />
              <span className="slider-val" id="val-border">1</span>
            </div>
            <div className="sb-swatches" id="border-colors" style={{marginTop:'0.5rem'}}>
              {[{c:'#cccccc',t:'Gray'},{c:'#000000',t:'Black'},{c:'#ffffff',t:'White'},{c:'#7c3aed',t:'Violet'}].map(({c,t},i) => (
                <div key={c} className={`color-swatch${i===0?' active':''}`} data-color={c} style={{background:c}} title={t}></div>
              ))}
            </div>
          </div>

          <div className="sb-divider"></div>

          <div className="sb-section">
            <h3 className="sb-title"><i className="ph ph-text-t"></i> Stamp</h3>
            <input type="text" id="stamp-name" placeholder="Name (optional)" className="sb-text-input" />
            <label className="sb-check-label">
              <input type="checkbox" id="stamp-date" /> Add date stamp
            </label>
          </div>

        </aside>

        {/* RIGHT: Main studio area */}
        <main className="studio-main">

          {/* Step 1 â€” Upload */}
          <div id="view-upload">
            <div className="studio-upload-zone" id="upload-zone">
              <i className="ph ph-cloud-arrow-up upload-icon"></i>
              <h3>Drop your photo here</h3>
              <p>JPG, PNG or WEBP &nbsp;Â·&nbsp; Max 15 MB</p>
              <button className="upload-btn" id="upload-btn">
                <i className="ph ph-folder-open"></i> Choose Photo
              </button>
              <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp" />
            </div>
            <div className="studio-tips">
              {[
                {icon:'ph-lock-simple',h:'100% Private',b:'Files stay in your browser only'},
                {icon:'ph-cpu',h:'On-Device AI',b:'Background removed locally'},
                {icon:'ph-globe-hemisphere-east',h:'50+ Presets',b:'India, USA, UAE, UK & more'},
              ].map(({icon,h,b}) => (
                <div className="tip-card" key={h}>
                  <i className={`ph ${icon}`}></i>
                  <strong>{h}</strong>
                  <span>{b}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Step 2 â€” Editor */}
          <div id="view-editor" style={{display:'none'}} className="studio-editor">
            <div className="studio-editor-toolbar">
              <span className="editor-label"><i className="ph ph-crop"></i> Crop &amp; Adjust</span>
              <div style={{display:'flex',gap:'0.5rem'}}>
                <button className="tool-btn tool-btn-ghost" id="btn-change-photo"><i className="ph ph-arrow-left"></i> Back</button>
                <button className="tool-btn tool-btn-accent" id="btn-remove-bg"><i className="ph ph-magic-wand"></i> Remove BG</button>
              </div>
            </div>
            <div className="canvas-wrapper" id="canvas-wrapper">
              <div className="canvas-placeholder" id="canvas-placeholder">
                <i className="ph ph-image"></i><p>Photo appears here</p>
              </div>
              <img id="cropper-img" alt="Crop" />
              <canvas id="preview-canvas"></canvas>
              <div className="ai-processing" id="ai-processing">
                <div className="ai-spinner"></div>
                <p>Processing on deviceâ€¦</p>
                <span>Removing background</span>
              </div>
            </div>
            <div className="tool-btn-row">
              <button className="tool-btn tool-btn-ghost" id="btn-reset"><i className="ph ph-arrow-counter-clockwise"></i> Reset</button>
              <button className="tool-btn tool-btn-ghost" id="btn-crop-apply"><i className="ph ph-check-circle"></i> Apply Crop</button>
              <button className="tool-btn tool-btn-primary" id="btn-generate"><i className="ph ph-images"></i> Generate Sheet</button>
            </div>
          </div>

          {/* Step 3 â€” Output */}
          <div id="view-output" style={{display:'none'}} className="studio-editor">
            <div className="studio-editor-toolbar">
              <span className="editor-label"><i className="ph ph-images"></i> Sheet Preview</span>
              <button className="tool-btn tool-btn-ghost" id="btn-back-edit"><i className="ph ph-arrow-left"></i> Edit</button>
            </div>
            <canvas id="output-canvas" style={{width:'100%',borderRadius:'12px',border:'1px solid rgba(0,0,0,0.08)'}}></canvas>
            <div className="tool-btn-row">
              <button className="tool-btn tool-btn-success" id="btn-download-pdf"><i className="ph ph-file-pdf"></i> Download PDF</button>
              <button className="tool-btn tool-btn-success" id="btn-download-png"><i className="ph ph-download-simple"></i> Download PNG</button>
            </div>
          </div>

        </main>
      </div>

      {/* â”€â”€â”€ FAQ â”€â”€â”€ */}
      <div className="studio-faq-wrap">
        <div className="studio-faq-inner">
          <div className="faq-heading">
            <i className="ph ph-chat-circle-text"></i>
            <h2>Common Questions</h2>
          </div>
          <div className="faq-list">
            {[
              {q:'How does background removal work offline?',a:'We use a compact AI model running inside your browser via WebAssembly. It downloads once, then works fully offline â€” no data ever sent anywhere.'},
              {q:'Will my photos be accepted by passport authorities?',a:'Yes â€” if you took a clear, well-lit shot. Our presets match India, USA, UAE, UK, and 50+ standards. Always verify against the latest guidelines of your issuing authority.'},
              {q:'Can I use this for Aadhaar, PAN, or visa applications?',a:'Absolutely. Pick a preset or enter custom dimensions. The cropper locks the correct aspect ratio for each document type automatically.'},
              {q:'Is there any watermark on downloaded photos?',a:'No watermarks, ever. What you download is exactly what you hand to a print shop â€” clean, plain photos.'},
              {q:'What formats can I upload?',a:'JPG, PNG, and WEBP images up to 15 MB. Use a well-lit shot with the subject clearly visible against any background for best AI results.'},
            ].map(({q,a}) => (
              <div className="faq-item" key={q}>
                <div className="faq-question" onClick={(e)=>{ if(window.toggleFaq) window.toggleFaq(e.currentTarget) }}>
                  {q}<i className="ph ph-caret-down faq-icon"></i>
                </div>
                <div className="faq-answer">{a}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </>
  )
}



